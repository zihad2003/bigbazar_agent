# ── Server ────────────────────────────────────────────────────────────────
PORT=3000

# ── Meta / Facebook ──────────────────────────────────────────────────────
META_VERIFY_TOKEN=choose_any_random_string_for_webhook_setup
META_APP_SECRET=from_meta_app_dashboard_basic_settings
PAGE_ACCESS_TOKEN=from_meta_app_dashboard_messenger_settings

# ── Groq ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── TiDB Cloud (your existing product database — READ ONLY) ─────────────
TIDB_HOST=gateway01.xx-region.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_username.root
TIDB_PASSWORD=your_password
TIDB_DATABASE=bigbazar

# ── Cloudflare D1 (agent state store — free SQLite database) ────────────
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_DATABASE_ID=your_database_id
CLOUDFLARE_API_TOKEN=your_api_token

# ── Telegram (moderator alerts) ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# ── Misc ─────────────────────────────────────────────────────────────────
BKASH_NUMBER=01XXXXXXXXX
ADMIN_SECRET=choose_any_random_string_for_admin_api

# ── Testing & Controls ───────────────────────────────────────────────────
AUTO_REPLY_ENABLED=true      # Set to false to disable the bot globally
TEST_MODE=false              # Set to true to only reply to tester PSIDs
TESTER_PSIDS=1234567,890123  # Comma-separated list of FB user IDs (PSIDs) allowed to test the bot
